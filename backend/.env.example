# ── Stellar Network ───────────────────────────────────────────
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org

# ── Contract Addresses (set after deployment) ─────────────────
FACTORY_CONTRACT_ADDRESS=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAABSC4
TREASURY_ADDRESS=

# ── Oracle Keypair (keep secret — use a secrets manager in prod) ─
ORACLE_KEYPAIR=SBAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAABSC4
ORACLE_PUBLIC_KEY=GAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAABSC4

# ── Admin ─────────────────────────────────────────────────────
ADMIN_JWT_SECRET=your-admin-jwt-secret-change-in-production
ADMIN_PUBLIC_KEY=GAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAABSC4
ADMIN_PRIVATE_KEY=SBAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAABSC4

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://boxmeout:boxmeout@localhost:5432/boxmeout

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── WebSocket ─────────────────────────────────────────────────
# Skip sending to a client when ws.bufferedAmount exceeds this (bytes)
WS_BUFFER_THRESHOLD_BYTES=16384

# ── API ───────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
JWT_SECRET=your-jwt-secret-change-in-production
ORACLE_API_KEY=your-oracle-api-key
LOG_LEVEL=info

# ── Indexer ───────────────────────────────────────────────────
GENESIS_LEDGER=100000
POLL_INTERVAL_MS=5000
# Ledgers replayed per batch when recovering a startup gap (max 1 batch/sec)
INDEXER_REPLAY_BATCH_SIZE=50
# Ledger gap above which replay is skipped (Sentry warning emitted instead)
INDEXER_MAX_REPLAY_LEDGERS=10000

# ── External Boxing Data API ──────────────────────────────────
BOXING_API_URL=https://api.example-boxing-data.com/v1

# ── Sentry ────────────────────────────────────────────────────
SENTRY_DSN=

# ── Email ─────────────────────────────────────────────────────
# Provider: smtp | sendgrid
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=no-reply@boxmeout.app
# Required when EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=SG.xxxx
APP_NAME=BoxMeOut
APP_BASE_URL=http://localhost:3001

# ── Risk Engine ───────────────────────────────────────────────
# imbalance_ratio = max(pool_a, pool_b) / total_pool
# Above MAX_IMBALANCE_RATIO  → warning alert
# Above CRITICAL_IMBALANCE_RATIO → market auto-locked
MAX_IMBALANCE_RATIO=0.90
CRITICAL_IMBALANCE_RATIO=0.95
# If a single market's total pool exceeds this (in XLM), no new bets accepted
MAX_MARKET_POOL_XLM=100000
# If the sum of all open market pools exceeds this (in XLM), market creation paused
MAX_PLATFORM_EXPOSURE_XLM=500000
# Admin email to receive risk alert emails
ADMIN_EMAIL=admin@boxmeout.app

# ── Treasury Sweep Configuration ──────────────────────────────
# Balance threshold (in XLM) that triggers an immediate sweep
TREASURY_SWEEP_THRESHOLD_XLM=1000

# Destination wallet address where swept Treasury funds are sent
TREASURY_WALLET_ADDRESS=GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Stellar contract ID for the Treasury smart contract
TREASURY_CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAABSC4

# ── Treasury Sweep Configuration ──────────────────────────────
# Balance threshold (in XLM) that triggers an immediate sweep
TREASURY_SWEEP_THRESHOLD_XLM=1000

# Destination wallet address where swept Treasury funds are sent
TREASURY_WALLET_ADDRESS=GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Stellar contract ID for the Treasury smart contract
TREASURY_CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAABSC4
